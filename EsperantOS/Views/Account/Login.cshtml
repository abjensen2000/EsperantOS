@model EsperantOS.Models.LoginViewModel

@{
    ViewData["Title"] = "Log ind";
    Layout = "_Layout";
}

<div class="shell shell-login">
    <div class="login-header">
        <h1 class="login-title">EsperantOS</h1>
    </div>
    <div class="login-body">
        <form asp-action="Login" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom:12px;font-size:13px;"></div>

            <div class="field">
                <label>Brugernavn</label>
                <input asp-for="Username" placeholder="Brugernavn" autocomplete="username" />
            </div>

            <div class="field">
                <label>Kodeord</label>
                <input asp-for="Password" type="password" placeholder="Kodeord" autocomplete="current-password" />
            </div>

            <button type="submit" class="btn btn-primary btn-lg">Log ind</button>
        </form>
    </div>
</div>
