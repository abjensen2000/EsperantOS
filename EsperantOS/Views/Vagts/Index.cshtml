@model IEnumerable<EsperantOS.Models.Vagt>

@{
    var dates = Model.Select(v => v.Dato.Date).Distinct().OrderBy(d => d).ToList();
    var firstDate = dates.FirstOrDefault();
}

<div class="shell">
    <div class="topbar">
        <span class="topbar-user">@User.Identity?.Name</span>
        <a asp-controller="Account" asp-action="Logout" class="topbar-logout">Log ud</a>
    </div>

    <div class="shell-body">
        <nav class="sidebar">
            <a asp-controller="Home" asp-action="Index" class="nav-btn">Forside</a>
            <button class="nav-btn active" data-view="vagtplan">Vagtplan</button>
            <button class="nav-btn" data-view="frigivede">Frigivede vagter</button>
            @if (User.IsInRole("Admin"))
            {
                <a asp-action="Create" class="nav-btn nav-btn-primary">+ Opret vagt</a>
            }
        </nav>

        <div class="main">
            <div class="date-tabs" id="dateTabs">
                @foreach (var date in dates)
                {
                    <span class="tab @(date == firstDate ? "active" : "")"
                          data-date="@date.ToString("yyyy-MM-dd")">
                        @date.ToString("d/M")
                    </span>
                }
            </div>

            <div id="shiftsContainer">
                @foreach (var date in dates)
                {
                    var shiftsOnDate = Model.Where(v => v.Dato.Date == date).ToList();
                    <div class="shift-list"
                         data-date-content="@date.ToString("yyyy-MM-dd")"
                         style="display: @(date == firstDate ? "flex" : "none");">

                        @foreach (var shift in shiftsOnDate)
                        {
                            var names = shift.Medarbejdere != null && shift.Medarbejdere.Any()
                                ? string.Join(", ", shift.Medarbejdere.Select(m => m.Name))
                                : "Ingen medarbejder";

                            <div class="shift-card @(shift.Frigivet ? "shift-card-released" : "")"
                                 data-frigivet="@shift.Frigivet.ToString().ToLower()">

                                <div>
                                    <div class="shift-date-label">@shift.Dato.ToString("d. MMMM yyyy")</div>
                                    <p class="shift-name">
                                        @if (shift.Frigivet)
                                        {
                                            <span>Fri vagt</span>
                                            <span class="shift-released-tag">(@names)</span>
                                        }
                                        else
                                        {
                                            <span>@names</span>
                                        }
                                    </p>
                                    <p class="shift-time">
                                        @shift.Dato.ToString("HH:mm") – @shift.Dato.AddHours(4).ToString("HH:mm")
                                    </p>
                                </div>

                                <div class="shift-right">
                                    @if (shift.Ædru)
                                    {
                                        <span class="badge badge-red">Ædru</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-green">Ikke ædru</span>
                                    }

                                    @if (!shift.Frigivet)
                                    {
                                        if (shift.Medarbejdere != null && shift.Medarbejdere.Any(m => m.Name == User.Identity.Name) || User.IsInRole("Admin"))
                                        {
                                            <button class="btn btn-release" data-id="@shift.Id">Frigiv</button>
                                        }
                                    }
                                    else
                                    {
                                        <button class="btn btn-take" data-id="@shift.Id">Tag vagt</button>
                                    }

                                    @if (User.IsInRole("Admin"))
                                    {
                                        <a asp-action="Edit" asp-route-id="@shift.Id" class="btn-icon" title="Rediger">✏</a>
                                        <a asp-action="Delete" asp-route-id="@shift.Id" class="btn-icon" title="Slet">✕</a>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>
