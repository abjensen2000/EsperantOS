@model EsperantOS.Models.Vagt

@{
    ViewData["Title"] = "Vagt detaljer";
}

<div class="shell">
    <div class="topbar">
        <span class="topbar-user">@User.Identity?.Name</span>
        <a asp-controller="Account" asp-action="Logout" class="topbar-logout">Log ud</a>
    </div>

    <div class="shell-body">
        <nav class="sidebar">
            <a asp-action="Index" class="nav-btn">Vagtplan</a>
        </nav>

        <div class="main main-pad">
            <h2 class="page-title">Vagt detaljer</h2>

            <table class="detail-table">
                <tr>
                    <th>Dato</th>
                    <td>@Model.Dato.ToString("d. MMMM yyyy HH:mm")</td>
                </tr>
                <tr>
                    <th>Ædru krævet</th>
                    <td>@(Model.Ædru ? "Ja" : "Nej")</td>
                </tr>
                <tr>
                    <th>Frigivet</th>
                    <td>@(Model.Frigivet ? "Ja" : "Nej")</td>
                </tr>
            </table>

            <div class="form-actions">
                @if (User.IsInRole("Admin"))
                {
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Rediger</a>
                }
                <a asp-action="Index" class="btn btn-secondary">Tilbage</a>
            </div>
        </div>
    </div>
</div>
