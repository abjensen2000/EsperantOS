@model EsperantOS.Models.Vagt

@{
    ViewData["Title"] = "Slet Vagt";
}

<div class="vagtplan-modal">
    <div class="modal-header">
        <a asp-action="Index" class="close-btn">&times;</a>
    </div>

    <div class="modal-body">
        <div class="sidebar">
            <a asp-action="Index" class="sidebar-btn">Vagtplan</a>
            <button class="sidebar-btn sidebar-btn-danger active">Slet Vagt (Admin)</button>
        </div>

        <div class="main-content main-content-padded">
            <h2 class="page-title-danger">Er du sikker på, at du vil slette denne vagt?</h2>

            <div class="shift-card shift-card-form">
                <div class="shift-details shift-details-col">
                    <dl class="row delete-info">
                        <dt class="col-sm-3">Dato</dt>
                        <dd class="col-sm-9">@Model.Dato.ToString("d. MMMM yyyy HH:mm")</dd>

                        <dt class="col-sm-3">Ædru Krævet?</dt>
                        <dd class="col-sm-9">@(Model.Ædru ? "Ja" : "Nej")</dd>

                        <dt class="col-sm-3">Er Frigivet?</dt>
                        <dd class="col-sm-9">@(Model.Frigivet ? "Ja" : "Nej")</dd>
                    </dl>

                    <div class="delete-actions">
                        <a asp-action="Index" class="btn-cancel">Annuller</a>
                        <form asp-action="Delete">
                            <input type="hidden" asp-for="Id" />
                            <button type="submit" class="btn-danger">Bekræft Sletning</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
