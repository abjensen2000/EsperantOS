@model EsperantOS.Models.Vagt

@{
    ViewData["Title"] = "Slet Vagt";
}

<div class="shell">
    <div class="topbar">
        <span class="topbar-user">@User.Identity?.Name@(User.IsInRole("Admin") ? " · Admin" : "")</span>
        <a asp-controller="Account" asp-action="Logout" class="topbar-logout">Log ud</a>
    </div>

    <div class="shell-body">
        <nav class="sidebar">
            <a asp-action="Index" class="nav-btn">Vagtplan</a>
            <button class="nav-btn nav-btn-danger active">Slet vagt</button>
        </nav>

        <div class="main main-pad">
            <h2 class="page-title-danger">Slet vagt</h2>

            <table class="detail-table">
                <tr>
                    <th>Dato</th>
                    <td>@Model.Dato.ToString("d. MMMM yyyy HH:mm")</td>
                </tr>
                <tr>
                    <th>Ædru krævet</th>
                    <td>@(Model.Ædru ? "Ja" : "Nej")</td>
                </tr>
                <tr>
                    <th>Frigivet</th>
                    <td>@(Model.Frigivet ? "Ja" : "Nej")</td>
                </tr>
            </table>

            <div class="form-actions">
                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-danger">Bekræft sletning</button>
                </form>
                <a asp-action="Index" class="btn btn-secondary">Annuller</a>
            </div>
        </div>
    </div>
</div>
