@model EsperantOS.Models.Vagt

@{
    ViewData["Title"] = "Slet Vagt";
}

<div class="vagtplan-modal">
    <div class="modal-header">
        <a asp-action="Index" class="close-btn" style="text-decoration: none;">&times;</a>
    </div>

    <div class="modal-body">
        <div class="sidebar">
            <a asp-action="Index" class="sidebar-btn" style="text-decoration:none; display:block; text-align:center;">Vagtplan</a>
            <button class="sidebar-btn active" style="background-color: #fee2e2; color: #991b1b; border-color: #f87171;">Slet Vagt (Admin)</button>
        </div>

        <div class="main-content" style="padding: 20px;">
            <h2 style="color: #ef4444; margin-top: 0;">Er du sikker på, at du vil slette denne vagt?</h2>
            
            <div class="shift-card" style="margin-top: 20px;">
                <div class="shift-details" style="flex-direction: column; align-items: flex-start;">
                    <dl class="row" style="color: #333; width: 100%;">
                        <dt class="col-sm-3">Dato</dt>
                        <dd class="col-sm-9">@Model.Dato.ToString("d. MMMM yyyy HH:mm")</dd>

                        <dt class="col-sm-3">Ædru Krævet?</dt>
                        <dd class="col-sm-9">@(Model.Ædru ? "Ja" : "Nej")</dd>

                        <dt class="col-sm-3">Er Frigivet?</dt>
                        <dd class="col-sm-9">@(Model.Frigivet ? "Ja" : "Nej")</dd>
                    </dl>

                    <div class="actions" style="margin-top: 20px; width: 100%; display: flex; justify-content: flex-end; gap: 10px;">
                        <a asp-action="Index" class="btn-release" style="background-color: #6b7280; text-decoration: none;">Annuller</a>
                        <form asp-action="Delete">
                            <input type="hidden" asp-for="Id" />
                            <button type="submit" class="btn-take" style="background-color: #ef4444; color: white; padding: 8px 16px; border: none; border-radius: 4px; cursor: pointer;">
                                Bekræft Sletning
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
