@model EsperantOS.Models.Vagt

@{
    ViewData["Title"] = "Rediger Vagt";
}

<div class="vagtplan-modal">
    <div class="modal-header">
        <a asp-action="Index" class="close-btn" style="text-decoration: none;">&times;</a>
    </div>

    <div class="modal-body">
        <div class="sidebar">
            <a asp-action="Index" class="sidebar-btn" style="text-decoration:none; display:block; text-align:center;">Vagtplan</a>
            <button class="sidebar-btn active">Rediger Vagt (Admin)</button>
        </div>

        <div class="main-content" style="padding: 20px;">
            <h2 style="color: #333; margin-top: 0;">Rediger Vagt</h2>
            
            <div class="shift-card" style="margin-top: 20px;">
                <form asp-action="Edit">
                    <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom: 10px; font-size: 14px;"></div>
                    <input type="hidden" asp-for="Id" />
                    
                    <h3 class="employee-name" style="color: #333; margin-top: 0; font-size: 18px;">Rediger Vagt Opsætning</h3>

                    <div class="shift-details" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 20px;">
                        
                        <!-- Tid Input -->
                        <div class="time-inputs" style="display: flex; gap: 20px; align-items: center;">
                            <div class="input-group" style="width: auto; display: flex; align-items: center; gap: 10px;">
                                <label style="font-size: 13px; margin-bottom: 0; color: #64748b; font-weight: bold;">DATO</label>
                                <div class="time-field" style="padding: 8px 15px; border-radius: 8px; background-color: #f8fafc; border: 1px solid #e2e8f0; display: flex; align-items: center;">
                                    <span class="icon" style="font-size: 18px; margin-right: 5px; display: flex; align-items: center;">📅</span>
                                    <select name="SelectedDate" asp-items="ViewBag.UpcomingFridays" style="background: transparent; border: none; outline: none; color: #334155; font-size: 16px; font-weight: bold; cursor: pointer;"></select>
                                </div>
                            </div>
                            
                            <div style="font-size: 20px; color: #cbd5e1; display: flex; align-items: center;">━</div>

                            <div class="input-group" style="width: auto; display: flex; align-items: center; gap: 10px;">
                                <label style="font-size: 13px; margin-bottom: 0; color: #64748b; font-weight: bold;">TID</label>
                                <div class="time-field" style="padding: 8px 15px; border-radius: 8px; background-color: #f8fafc; border: 1px solid #e2e8f0; display: flex; align-items: center;">
                                    <span class="icon" style="font-size: 18px; margin-right: 5px; display: flex; align-items: center;">🕒</span>
                                    <select name="SelectedTime" asp-items="ViewBag.Times" style="background: transparent; border: none; outline: none; color: #334155; font-size: 16px; font-weight: bold; cursor: pointer;"></select>
                                </div>
                            </div>
                            
                            <span asp-validation-for="Dato" class="text-danger" style="font-size: 13px;"></span>
                        </div>

                        <!-- Checkboxes & Knap -->
                        <div class="actions" style="display: flex; align-items: center; gap: 20px;">
                            
                            <div style="display: flex; flex-direction: column; gap: 10px;">
                                <div style="display: flex; align-items: center; gap: 8px;">
                                    <input class="form-check-input" asp-for="Ædru" style="width: 18px; height: 18px; cursor: pointer; margin: 0;" /> 
                                    <label style="color: #64748b; font-weight: bold; font-size: 13px; cursor: pointer; margin: 0;">KRÆVER ÆDRU</label>
                                </div>
                                <div style="display: flex; align-items: center; gap: 8px;">
                                    <input class="form-check-input" asp-for="Frigivet" style="width: 18px; height: 18px; cursor: pointer; margin: 0;" />
                                    <label style="color: #64748b; font-weight: bold; font-size: 13px; cursor: pointer; margin: 0;">ER FRIGIVET (LEDIG)</label>
                                </div>
                            </div>

                            <button type="submit" class="btn-take" style="background-color: #3b82f6; color: white; padding: 12px 20px; border: none; border-radius: 6px; cursor: pointer; font-weight: bold; font-size: 15px; height: 100%;">
                                Gem ændringer
                            </button>
                            
                        </div>

                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
