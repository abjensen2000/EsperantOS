@model EsperantOS.Models.Vagt

@{
    ViewData["Title"] = "Rediger Vagt";
}

<div class="vagtplan-modal">
    <div class="modal-header">
        <a asp-action="Index" class="close-btn">&times;</a>
    </div>

    <div class="modal-body">
        <div class="sidebar">
            <a asp-action="Index" class="sidebar-btn">Vagtplan</a>
            <button class="sidebar-btn active">Rediger Vagt (Admin)</button>
        </div>

        <div class="main-content main-content-padded">
            <h2 class="page-title">Rediger Vagt</h2>

            <div class="shift-card shift-card-form">
                <form asp-action="Edit">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <input type="hidden" asp-for="Id" />

                    <h3 class="form-title">Rediger Vagt Opsætning</h3>

                    <div class="shift-details shift-details-wrap">

                        <div class="time-inputs">
                            <div class="time-input-group">
                                <label class="time-input-label">DATO</label>
                                <div class="time-field-styled">
                                    <span class="icon">📅</span>
                                    <select name="SelectedDate" asp-items="ViewBag.UpcomingFridays" class="select-field"></select>
                                </div>
                            </div>

                            <div class="time-separator">━</div>

                            <div class="time-input-group">
                                <label class="time-input-label">TID</label>
                                <div class="time-field-styled">
                                    <span class="icon">🕒</span>
                                    <select name="SelectedTime" asp-items="ViewBag.Times" class="select-field"></select>
                                </div>
                            </div>

                            <span asp-validation-for="Dato" class="text-danger"></span>
                        </div>

                        <div class="form-actions">
                            <div class="checkbox-stack">
                                <div class="checkbox-row">
                                    <input class="form-check-input checkbox-input" asp-for="Ædru" />
                                    <label class="checkbox-label">KRÆVER ÆDRU</label>
                                </div>
                                <div class="checkbox-row">
                                    <input class="form-check-input checkbox-input" asp-for="Frigivet" />
                                    <label class="checkbox-label">ER FRIGIVET (LEDIG)</label>
                                </div>
                            </div>

                            <button type="submit" class="btn-primary-action">Gem ændringer</button>
                        </div>

                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
