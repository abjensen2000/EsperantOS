@model EsperantOS.Models.Vagt

@{
    ViewData["Title"] = "Rediger Vagt";
}

<div class="shell">
    <div class="topbar">
        <span class="topbar-user">@User.Identity?.Name</span>
        <a asp-controller="Account" asp-action="Logout" class="topbar-logout">Log ud</a>
    </div>

    <div class="shell-body">
        <nav class="sidebar">
            <a asp-action="Index" class="nav-btn">Vagtplan</a>
            <button class="nav-btn active">Rediger vagt</button>
        </nav>

        <div class="main main-pad">
            <h2 class="page-title">Rediger vagt</h2>

            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom:12px;font-size:13px;"></div>
                <input type="hidden" asp-for="Id" />

                <div class="field-row">
                    <div class="field">
                        <label>Dato</label>
                        <select name="SelectedDate" asp-items="ViewBag.UpcomingFridays"></select>
                        <span asp-validation-for="Dato" class="text-danger"></span>
                    </div>
                    <div class="field">
                        <label>Tidspunkt</label>
                        <select name="SelectedTime" asp-items="ViewBag.Times"></select>
                    </div>
                </div>

                <div class="checkbox-row">
                    <input asp-for="Ædru" type="checkbox" />
                    <label asp-for="Ædru">Kræver ædru</label>
                </div>
                <div class="checkbox-row">
                    <input asp-for="Frigivet" type="checkbox" />
                    <label asp-for="Frigivet">Frigivet (ledig)</label>
                </div>

                <div class="form-actions" style="margin-top:20px;">
                    <button type="submit" class="btn btn-primary">Gem ændringer</button>
                    <a asp-action="Index" class="btn btn-secondary">Annuller</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
