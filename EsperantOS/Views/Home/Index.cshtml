@model EsperantOS.Models.HomeViewModel

@{
    ViewData["Title"] = "Forside";
}

<div class="shell">
    <div class="topbar">
        <span class="topbar-user">@User.Identity?.Name</span>
        <a asp-controller="Account" asp-action="Logout" class="topbar-logout">Log ud</a>
    </div>

    <div class="shell-body">
        <nav class="sidebar">
            <button class="nav-btn active" data-view="forside">Forside</button>
            <a asp-controller="Vagts" asp-action="Index" asp-route-view="vagtplan" class="nav-btn">Vagtplan</a>
            <a asp-controller="Vagts" asp-action="Index" asp-route-view="frigivede" class="nav-btn">Frigivede vagter</a>
        </nav>

        <div class="main main-pad">
            <h1 class="page-title">Dashboard</h1>

            <div class="dashboard-grid">

                <div>
                    <div class="notice-card">
                        <p class="notice-title">Beskeder fra bestyrelsen</p>
                        <p class="notice-text">@Model.BestyrelsesBesked</p>
                    </div>
                </div>

                <div>
                    <p class="section-title">Mine kommende vagter</p>

                    @if (Model.MineVagter != null && Model.MineVagter.Any(v => !v.Frigivet))
                    {
                        @foreach (var vagt in Model.MineVagter.Where(v => !v.Frigivet).Take(3))
                        {
                            <div class="shift-mini">
                                <div class="shift-mini-date">
                                    @vagt.Dato.ToString("dddd d. MMM yyyy", new System.Globalization.CultureInfo("da-DK"))
                                </div>
                                <div class="shift-mini-time">
                                    @vagt.Dato.ToString("HH:mm") – @vagt.Dato.AddHours(4).ToString("HH:mm")
                                </div>
                                <div class="shift-mini-row">
                                    @if (vagt.Ædru)
                                    {
                                        <span class="badge badge-red">Ædru</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-green">Ikke ædru</span>
                                    }
                                    <a asp-controller="Vagts" asp-action="Index" class="link">Gå til vagtplan →</a>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="shift-card shift-card-empty">
                            <p>Du har ingen planlagte vagter.</p>
                            <a asp-controller="Vagts" asp-action="Index" asp-route-view="frigivede" class="btn btn-primary">Tag en vagt</a>
                        </div>
                    }
                </div>

            </div>
        </div>
    </div>
</div>
