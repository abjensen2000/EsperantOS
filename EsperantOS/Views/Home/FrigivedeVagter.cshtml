@using System.Security.Claims
@using DTO.Model
@{
    ViewData["Title"] = "Home Page";
    var isAuthenticated = User.Identity?.IsAuthenticated ?? false;
    var userName = User.FindFirst(ClaimTypes.Name)?.Value ?? "Ukendt";
    var isBestyrelsesmedlem = User.FindFirst("ErBestyrelsesmedlem")?.Value == "True";
}

@if (isAuthenticated)
{
    <div style="background-color: #333; color: white; padding: 15px; display: flex; justify-content: space-between; align-items: center;">
        <div>
            <strong>Logget ind som: @userName</strong>
            @if (isBestyrelsesmedlem)
            {
                <span style="margin-left: 15px; color: #ffc107;">⭐ Bestyrelsesmedlem</span>
            }
        </div>
        <form method="post" action="/auth/logout" style="margin: 0;">
            <button type="submit" style="padding: 8px 15px; background-color: #dc3545; color: white; border: none; border-radius: 4px; cursor: pointer;">Logout</button>
        </form>
    </div>
}
else
{
    <div style="text-align: center; padding: 20px; background-color: #f8d7da; color: #721c24;">
        <p>Du er ikke logget ind. <a href="/auth/login" style="color: #721c24; font-weight: bold;">Gå til login</a></p>
    </div>
}

<div style="grid-column:1; grid-row:2; justify-content:start; margin:0px" class="btn-group-vertical">
    <button style="margin:4px; width:80px; border-radius:6px">
        Forside
    </button>
    <button style="margin:4px; width:80px; border-radius:6px">
        Vagtplan
    </button>
    <button style="margin:4px; width:80px; border-radius:6px">
        Frigivede vagter
    </button>
</div>

<div style="display:grid; grid-template-columns:100px auto 30px; gap:5px; grid-template-rows:30px auto 30px; background-color:lightgray">
    <div class="text-center" style="background-color:white; grid-column:2; grid-row:2">
        <h1>HER ER FRIGIVEDE VAGTER!</h1>

        <ul>
            @{
                foreach (VagtDTO vagt in ViewBag.vagter)
                { 
                    <li>
                        <p>@vagt.Dato</p>
                        @if (vagt.Ædru){ <p> Ædru </p>}
                        else{<p>Ikke ædru</p>}
                    </li>

                }

            }
        </ul>
    </div>


</div>


